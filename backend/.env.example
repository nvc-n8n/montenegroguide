# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/montenegro_guide
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/montenegro_guide

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Storage
STORAGE_BACKEND=local
MEDIA_ROOT=./media
MEDIA_URL=/media

# S3 (for production)
# S3_BUCKET=montenegro-guide
# S3_REGION=eu-central-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT_URL=

# Image processing
THUMBNAIL_WIDTH=400
THUMBNAIL_HEIGHT=300
IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1080
