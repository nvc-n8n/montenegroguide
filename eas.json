{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_USE_MOCK_API": "false",
        "EXPO_PUBLIC_API_BASE_URL": "https://montenegro-guide-api.fly.dev/api/v1"
      }
    },
    "preview-sim": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_USE_MOCK_API": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_USE_MOCK_API": "false",
        "EXPO_PUBLIC_API_BASE_URL": "https://montenegro-guide-api.fly.dev/api/v1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
